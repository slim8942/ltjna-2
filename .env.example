# ─── Email (Nodemailer) ──────────────────────────────────────────────────────
# For Gmail: enable "App Passwords" in your Google account
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
NOTIFY_EMAIL=leads@ltjna.com          # Where new lead notifications are sent

# ─── Admin Dashboard ─────────────────────────────────────────────────────────
ADMIN_SECRET=change_me_to_a_strong_random_string

# ─── Calendly ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/your-ltjna-handle
